# =============================================
flutter_app/.idea/
flutter_app/*.iml
flutter_app/*.ipr
flutter_app/*.iws
.DS_Store
Thumbs.db

# =============================================
# Firebase Local Cache
# =============================================
flutter_app/.firebase/

# =============================================
# Android Build
# =============================================
flutter_app/android/app/debug/
flutter_app/android/app/profile/
flutter_app/android/app/release/
flutter_app/android/.gradle/
flutter_app/android/local.properties

# =============================================
# iOS Build
# =============================================
flutter_app/ios/.last_build_id

# =============================================
# Logs
